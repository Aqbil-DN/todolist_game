# ---------------------------------------------------------------------------
# Backend configuration. Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# PostgreSQL connection URL (e.g. Supabase). PostgreSQL is UTF-8 by default,
# so emoji catalog data is preserved without extra charset flags.
# Supabase requires TLS; append ?sslmode=require if your client does not
# negotiate SSL automatically. For IPv4-only networks, prefer the Supabase
# connection pooler host (aws-0-<region>.pooler.supabase.com:5432).
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Path to your Firebase service-account JSON key (used to verify ID tokens).
# Leave empty to fall back to Application Default Credentials.
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# Comma-separated list of allowed CORS origins (the Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
