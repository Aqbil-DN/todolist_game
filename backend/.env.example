# ---------------------------------------------------------------------------
# Backend configuration. Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# Full pyodbc ODBC connection string for your Azure Database for MySQL.
# Requires the "MySQL Connector/ODBC 8.x Unicode Driver" to be installed.
# CHARSET=utf8mb4 is required for emoji storage; Azure MySQL requires SSL.
PYODBC_CONNECTION_STRING=DRIVER={MySQL ODBC 8.0 Unicode Driver};SERVER=your-server.mysql.database.azure.com;PORT=3306;DATABASE=todolist_game;UID=your_user;PWD=your_password;CHARSET=utf8mb4;SSLMODE=REQUIRED;

# Path to your Firebase service-account JSON key (used to verify ID tokens).
# Leave empty to fall back to Application Default Credentials.
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# Comma-separated list of allowed CORS origins (the Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
